SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
PORT=5000

# API bootstraps `admins.password_hash` on every server start (same defaults as ensure-admin.mjs).
# Override email/password here; set DISABLE_ADMIN_BOOTSTRAP=1 to disable boot sync entirely.
ADMIN_SEED_EMAIL=admin@new.com
ADMIN_SEED_PASSWORD=admin123!
# DISABLE_ADMIN_BOOTSTRAP=1

# Optional: multi-step JSON logs for POST /api/admin/login (default is one safe summary line per request).
# ADMIN_LOGIN_VERBOSE=1

# One-time: POST /api/admin/sync-credentials with header X-Admin-Sync-Token (same value) and JSON body { "email", "password" }.
# Set on the host, call once, then remove ADMIN_SYNC_TOKEN from env.
# ADMIN_SYNC_TOKEN=

# production: set NODE_ENV=production
NODE_ENV=development

# Comma-separated allowed browser origins (omit in dev to allow all)
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Behind reverse proxy (nginx, render, fly) for correct client IPs with rate limiting
# TRUST_PROXY=1

# RATE_LIMIT_MAX=100
# RATE_LIMIT_AUTH_MAX=30

# Terminate TLS at the proxy; serve HTTP only from Node and use HTTPS at the edge.

# One-off password reset (same bcrypt as login): `npm run reset:admin-password-once`
# RESET_ADMIN_CONFIRM=yes
# RESET_ADMIN_EMAIL=admin@new.com
# RESET_ADMIN_PASSWORD=your-new-password
