SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
PORT=5000

# Used by `npm run seed:admin` to create/repair the admin login row.
# Leave defaults (admin@new.com / admin123!) or override here.
ADMIN_SEED_EMAIL=admin@new.com
ADMIN_SEED_PASSWORD=admin123!

# production: set NODE_ENV=production
NODE_ENV=development

# Comma-separated allowed browser origins (omit in dev to allow all)
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Behind reverse proxy (nginx, render, fly) for correct client IPs with rate limiting
# TRUST_PROXY=1

# RATE_LIMIT_MAX=100
# RATE_LIMIT_AUTH_MAX=30

# Terminate TLS at the proxy; serve HTTP only from Node and use HTTPS at the edge.
